# IG Trading Bot - Environment Configuration
# Long-term growth trading with IG.com
# Copy this file to .env and fill in your credentials

# =============================================================================
# IG API CREDENTIALS (Required)
# Get these from your IG account dashboard under Settings > API
# =============================================================================

# Your IG API key (found in IG Labs / API settings)
IG_API_KEY=your_api_key_here

# Your IG account login identifier (username)
IG_IDENTIFIER=your_username_here

# Your IG account password
IG_PASSWORD=your_password_here

# Your IG account ID (found in account settings, usually starts with letters)
IG_ACCOUNT_ID=your_account_id_here

# =============================================================================
# TELEGRAM BOT CONFIGURATION (Required for notifications)
# Create a bot via @BotFather on Telegram
# =============================================================================

# Your Telegram bot token (from @BotFather)
TG_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (use @userinfobot to find yours)
TG_CHAT_ID=your_chat_id_here

# =============================================================================
# TRADING PARAMETERS - ADJUSTABLE
# All values can be changed anytime by editing this file
# =============================================================================

# Dollar-Cost Averaging amount (in AED)
# How much to invest each month on DCA_DAY
DCA_AMOUNT=2500

# Day of month for DCA purchases (1-31)
# Set to a day when you usually have funds available
DCA_DAY=1

# Maximum percentage of portfolio per position (safety limit)
MAX_POSITION_PCT=20

# Maximum number of different assets to hold
MAX_POSITIONS=5

# Minimum cash buffer to keep uninvested (in AED)
MIN_CASH_BUFFER=1000

# =============================================================================
# RISK MANAGEMENT SETTINGS
# Conservative settings for long-term growth
# =============================================================================

# Stop-loss percentage (negative number)
# Position will be sold if it drops this much from purchase price
STOP_LOSS_PERCENTAGE=-10

# Take-profit percentage (positive number)
# Position will be sold if it rises this much
TAKE_PROFIT_PERCENTAGE=25

# Enable trailing stop? (true/false)
# Stop-loss moves up as price rises, protecting profits
TRAILING_STOP=true

# Trailing stop distance percentage
TRAILING_STOP_DISTANCE=10

# =============================================================================
# TECHNICAL ANALYSIS SETTINGS
# =============================================================================

# EMA periods for trend analysis
EMA_SHORT_PERIOD=50
EMA_LONG_PERIOD=200

# Trend threshold (as decimal, e.g. 0.02 = 2%)
# How strong trend must be to trigger "STRONG" signal
TREND_THRESHOLD=0.02

# =============================================================================
# REBALANCING SETTINGS
# =============================================================================

# How often to check for rebalancing (monthly or quarterly)
REBALANCE_FREQUENCY=monthly

# Minimum drift percentage before rebalancing triggers
# e.g. if target is 20% but actual is 28%, drift is 8%
REBALANCE_THRESHOLD=5

# =============================================================================
# MODE SETTINGS
# =============================================================================

# Use demo account? (true/false)
# IMPORTANT: Always start with 'true' for testing!
# Change to 'false' only when ready for live trading
USE_DEMO=true

# =============================================================================
# OPTIONAL: CUSTOM ASSET LIST
# Uncomment and modify to change which assets to trade
# Default: SPY, QQQ, VTI, VXUS, BND, AAPL, MSFT, GOOGL
# =============================================================================

# ASSETS=AAPL,MSFT,GOOGL,AMZN,TSLA

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. ACCOUNT TYPE: This bot uses IG INVEST (cash equities), NOT CFDs/spread bets
#    - Lower fees for long-term holding
#    - No overnight financing costs
#    - You own the actual shares
#
# 2. CURRENCY: Bot is configured for AED (UAE Dirham)
#    - IG has DFSA-regulated entity in Dubai
#    - Change to EUR, GBP, or USD if needed
#
# 3. DEMO MODE: Always test in demo mode first!
#    - IG provides demo accounts with virtual money
#    - Switch to live only after thorough testing
#
# 4. DCA STRATEGY: 
#    - Invests fixed amount on fixed schedule
#    - Removes emotion from investing
#    - Works best over long time periods (years)
#
# 5. SAFETY LIMITS:
#    - Max 20% per position = diversification
#    - Stop-loss at -10% = loss protection
#    - Max 5 positions = concentration limit
#
# =============================================================================
